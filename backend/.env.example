# ============================================================
# Variáveis de Ambiente - backend2
# ============================================================
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env no repositório.

# API Key do Groq para inferência rápida na nuvem.
# Obtenha em: https://console.groq.com/
GROQ_API_KEY=sua_chave_groq_aqui

# String de conexão PostgreSQL (Supabase).
# Formato: postgresql://postgres:[SENHA]@db.[PROJECT].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:[SENHA]@db.SEU_PROJETO.supabase.co:5432/postgres

# API Key do OpenRouter como fallback.
# Obtenha em: https://openrouter.ai/
OPENROUTER_API_KEY=sua_chave_openrouter_aqui
